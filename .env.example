# Chain platform 顶层环境变量
# 复制为 chain_platform/.env 后填值（已在 .gitignore，不会入库）
#
# 这一份文件同时被：
#   1) chain_fastapi_server/app/core/config.py（env_file="../.env" 即 chain_platform/.env）
#   2) docker-compose.dev.yml（POSTGRES_USER / PASSWORD / DB 等）
# 读取。请在此一处维护，不要在 chain_fastapi_server/ 内再放 .env。

# ─── 域名 / 前端 ─────────────────────────────────────────────────────
DOMAIN=localhost
# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5173

# Environment: local, staging, production
ENVIRONMENT=local

# ─── 项目元数据 ──────────────────────────────────────────────────────
PROJECT_NAME=chain
VERSION=0.1.0
STACK_NAME=chain-fastapi-server

# ─── 后端核心 ────────────────────────────────────────────────────────
# 允许的 CORS 来源（逗号分隔；Web/Mobile 本地端口都加上）
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:5174,https://localhost"

# JWT / 密码哈希（生产必须改）
SECRET_KEY=changethis

# 初始管理员（首次启动会自动创建）
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# ─── 邮件（默认关闭，需要时再填） ─────────────────────────────────────
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# ─── PostgreSQL（docker-compose 与后端共用） ───────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# ─── MongoDB（非结构化数据；不填则 health 显示 false 但不影响启动） ─────
MONGO_URL=mongodb://localhost:27017/chain

# ─── Redis（缓存/任务队列；不填则 health 显示 false 但不影响启动） ──────
REDIS_URL=redis://localhost:6379/0

# ─── 监控（可选） ────────────────────────────────────────────────────
SENTRY_DSN=

# ─── 部署镜像（生产 docker-compose 用） ───────────────────────────────
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
